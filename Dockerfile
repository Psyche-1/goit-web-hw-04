# Використовуємо офіційний легкий образ Python
FROM python:3.11-slim

# Встановлюємо робочу директорію всередині контейнера
WORKDIR /app

# Копіюємо всі файли проекту (main.py, html-файли, css, логотип) у контейнер
COPY . .

# Створюємо папку для збереження даних (на випадок, якщо її немає)
RUN mkdir -p storage

# Відкриваємо порти: 3000 для HTTP та 5000/udp для Socket-сервера
EXPOSE 3000
EXPOSE 5000/udp

# Запускаємо додаток
CMD ["python", "main.py"]
